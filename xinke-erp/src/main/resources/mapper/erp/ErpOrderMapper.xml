<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xinke.erp.mapper.ErpOrderMapper">
    <resultMap id="ErpOrderItemResult" type="ErpOrderItem">
        <id property="orderItemId" column="order_item_id"/>
        <result property="orderId" column="order_id"/>
        <result property="shopId" column="shop_id"/>
        <result property="shopName" column="shop_name"/>
        <result property="productId" column="product_id"/>
        <result property="productName" column="product_name"/>
        <result property="skuId" column="sku_id"/>
        <result property="skuName" column="sku_name"/>
        <result property="quantity" column="quantity"/>
        <result property="payAmount" column="pay_amount"/>
        <result property="productCost" column="product_cost"/>
        <result property="platformFee" column="platform_fee"/>
        <result property="adCost" column="ad_cost"/>
        <result property="freightFee" column="freight_fee"/>
        <result property="refundCost" column="refund_cost"/>
        <result property="profitAmount" column="profit_amount"/>
        <result property="orderStatus" column="order_status"/>
        <result property="payTime" column="pay_time"/>
        <result property="dt" column="dt"/>
    </resultMap>

    <sql id="selectOrderItemVo">
        select order_item_id, order_id, shop_id, shop_name, product_id, product_name, sku_id, sku_name,
               quantity, pay_amount, product_cost, platform_fee, ad_cost, freight_fee, refund_cost,
               profit_amount, order_status, pay_time, dt
        from dwd_order_item
    </sql>

    <select id="selectOrderItemList" parameterType="ErpOrderItem" resultMap="ErpOrderItemResult">
        <include refid="selectOrderItemVo"/>
        <where>
            <if test="orderId != null">and order_id = #{orderId}</if>
            <if test="shopName != null and shopName != ''">and shop_name like concat('%', #{shopName}, '%')</if>
            <if test="productName != null and productName != ''">and product_name like concat('%', #{productName}, '%')</if>
            <if test="orderStatus != null">and order_status = #{orderStatus}</if>
        </where>
        order by pay_time desc, order_item_id desc
    </select>

    <select id="selectOrderItemById" parameterType="Long" resultMap="ErpOrderItemResult">
        <include refid="selectOrderItemVo"/>
        where order_item_id = #{orderItemId}
    </select>
</mapper>
