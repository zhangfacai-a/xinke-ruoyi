<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.erp.mapper.ErpInventoryMovementMapper">
    <resultMap id="ErpInventoryMovementResult" type="ErpInventoryMovement">
        <id property="movementId" column="movement_id"/>
        <result property="movementNo" column="movement_no"/>
        <result property="warehouseId" column="warehouse_id"/>
        <result property="warehouseName" column="warehouse_name"/>
        <result property="skuId" column="sku_id"/>
        <result property="skuCode" column="sku_code"/>
        <result property="skuName" column="sku_name"/>
        <result property="movementType" column="movement_type"/>
        <result property="sourceType" column="source_type"/>
        <result property="sourceNo" column="source_no"/>
        <result property="quantity" column="quantity"/>
        <result property="beforeQty" column="before_qty"/>
        <result property="afterQty" column="after_qty"/>
        <result property="costPrice" column="cost_price"/>
        <result property="operatorName" column="operator_name"/>
        <result property="movementTime" column="movement_time"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <select id="selectMovementList" parameterType="ErpInventoryMovement" resultMap="ErpInventoryMovementResult">
        select m.movement_id, m.movement_no, m.warehouse_id, w.warehouse_name, m.sku_id,
               s.sku_code, s.sku_name, m.movement_type, m.source_type, m.source_no,
               m.quantity, m.before_qty, m.after_qty, m.cost_price, m.operator_name,
               m.movement_time, m.create_by, m.create_time, m.remark
        from erp_inventory_movement m
        left join erp_warehouse w on w.warehouse_id = m.warehouse_id
        left join erp_product_sku s on s.sku_id = m.sku_id
        <where>
            <if test="movementNo != null and movementNo != ''">and m.movement_no like concat('%', #{movementNo}, '%')</if>
            <if test="warehouseName != null and warehouseName != ''">and w.warehouse_name like concat('%', #{warehouseName}, '%')</if>
            <if test="skuCode != null and skuCode != ''">and s.sku_code like concat('%', #{skuCode}, '%')</if>
            <if test="skuName != null and skuName != ''">and s.sku_name like concat('%', #{skuName}, '%')</if>
            <if test="movementType != null and movementType != ''">and m.movement_type = #{movementType}</if>
            <if test="sourceNo != null and sourceNo != ''">and m.source_no like concat('%', #{sourceNo}, '%')</if>
        </where>
        order by m.movement_id desc
    </select>
</mapper>
