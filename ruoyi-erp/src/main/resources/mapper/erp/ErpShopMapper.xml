<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.erp.mapper.ErpShopMapper">
    <resultMap id="ErpShopResult" type="ErpShop">
        <id property="shopId" column="shop_id"/>
        <result property="shopCode" column="shop_code"/>
        <result property="shopName" column="shop_name"/>
        <result property="platformCode" column="platform_code"/>
        <result property="platformName" column="platform_name"/>
        <result property="ownerName" column="owner_name"/>
        <result property="status" column="status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectShopVo">
        select shop_id, shop_code, shop_name, platform_code, platform_name, owner_name,
               status, create_by, create_time, update_by, update_time, remark
        from erp_shop
    </sql>

    <select id="selectShopList" parameterType="ErpShop" resultMap="ErpShopResult">
        <include refid="selectShopVo"/>
        <where>
            <if test="shopCode != null and shopCode != ''">and shop_code like concat('%', #{shopCode}, '%')</if>
            <if test="shopName != null and shopName != ''">and shop_name like concat('%', #{shopName}, '%')</if>
            <if test="platformName != null and platformName != ''">and platform_name like concat('%', #{platformName}, '%')</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by shop_id desc
    </select>

    <select id="selectShopById" parameterType="Long" resultMap="ErpShopResult">
        <include refid="selectShopVo"/>
        where shop_id = #{shopId}
    </select>

    <insert id="insertShop" parameterType="ErpShop" useGeneratedKeys="true" keyProperty="shopId">
        insert into erp_shop(shop_code, shop_name, platform_code, platform_name, owner_name, status, create_by, create_time, remark)
        values(#{shopCode}, #{shopName}, #{platformCode}, #{platformName}, #{ownerName}, #{status}, #{createBy}, sysdate(), #{remark})
    </insert>

    <update id="updateShop" parameterType="ErpShop">
        update erp_shop
        <set>
            <if test="shopCode != null">shop_code = #{shopCode},</if>
            <if test="shopName != null">shop_name = #{shopName},</if>
            <if test="platformCode != null">platform_code = #{platformCode},</if>
            <if test="platformName != null">platform_name = #{platformName},</if>
            <if test="ownerName != null">owner_name = #{ownerName},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where shop_id = #{shopId}
    </update>

    <delete id="deleteShopByIds" parameterType="Long">
        delete from erp_shop where shop_id in
        <foreach collection="array" item="shopId" open="(" separator="," close=")">
            #{shopId}
        </foreach>
    </delete>
</mapper>
